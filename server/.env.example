PORT=4000
NODE_ENV=development
DATABASE_URL="file:./dev.db"
JWT_SECRET="change_me_to_a_long_random_secret_min_32_chars"
JWT_EXPIRES_IN="7d"
CLIENT_ORIGIN="http://localhost:5173"

# Stripe (https://dashboard.stripe.com)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
VITE_STRIPE_PUBLIC_KEY=pk_test_...

# Cloudinary (https://cloudinary.com)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Resend email (https://resend.com) — logs to console if not set
RESEND_API_KEY=
EMAIL_FROM="ParkSpot <noreply@parkspot.com>"

# Mapbox (https://mapbox.com) — skip geocoding if not set
MAPBOX_TOKEN=
