PORT=4000
NODE_ENV=development

# PostgreSQL (Railway provides this automatically as DATABASE_URL)
# For local dev you can use a local Postgres instance or Docker:
#   docker run -e POSTGRES_PASSWORD=pass -p 5432:5432 postgres
DATABASE_URL="postgresql://user:password@localhost:5432/parkspot"

# Long random string — generate with: openssl rand -base64 32
JWT_SECRET="change_me_to_a_long_random_secret"
JWT_EXPIRES_IN="7d"

# Comma-separated list of allowed frontend origins
# In production: your Vercel URL, e.g. https://parkspot.vercel.app
CLIENT_ORIGIN="http://localhost:5173"
